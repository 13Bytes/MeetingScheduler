# Convex writes these during `npm run convex:dev`.
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_SITE_URL=
NEXT_PUBLIC_CONVEX_URL=

# Required in production for Stage 7 passwordless email recovery.
MEETING_SCHEDULER_IDENTITY_SESSION_SECRET=
MEETING_SCHEDULER_IDENTITY_INTERNAL_SECRET=

# Local development only. Never enable in production.
MEETING_SCHEDULER_ALLOW_DEV_IDENTITY_SECRET=
MEETING_SCHEDULER_DEV_EXPOSE_MAGIC_LINKS=
MEETING_SCHEDULER_EMAIL_DEV_LOG_CONTENT=

# Email delivery. Local development defaults to the safe development adapter.
MEETING_SCHEDULER_APP_URL=
MEETING_SCHEDULER_EMAIL_PROVIDER=
MEETING_SCHEDULER_NOTIFICATION_PROCESS_SECRET=
EMAIL_FROM=
EMAIL_PROVIDER_API_KEY=
RESEND_API_KEY=
